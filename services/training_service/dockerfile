FROM ghcr.io/astral-sh/uv:python3.12-bookworm-slim

WORKDIR /training

# Install git system dependency (required by MLflow)
RUN apt-get update && apt-get install -y git && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml uv.lock ./

RUN uv sync --no-dev --group training_ml

COPY services/training_service/src/ ./src/
COPY services/training_service/config/ ./config/

RUN mkdir -p /training/data/raw \
    /training/data/processed \
    /training/models \
    /training/metrics \
    /training/logs

ENV PYTHONPATH="/training:/training/src"
ENV PATH="/training/.venv/bin:$PATH"

CMD ["python", "src/train.py"]